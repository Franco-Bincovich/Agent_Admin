# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Campañas de Deuda · Backend
# Copiar a .env y completar con valores reales.
# NUNCA commitear el .env real — está bloqueado en .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_ENV=development

# Anthropic (Agentes 1–4)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Perplexity (Agente Economista — contexto macro)
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — dejar vacío hasta que se habilite la DB (Sesión 2+)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Auth JWT (mínimo 32 caracteres)
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-production
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=30

# CORS — lista separada por comas (sin espacios)
ALLOWED_ORIGINS=http://localhost:3000

# Gmail OAuth (Sesión 19)
GMAIL_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# Payload máximo en bytes (default: 10 MB)
MAX_PAYLOAD_BYTES=10485760
